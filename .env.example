# ── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321   # Telegram IDs через запятую для /admin, /grant, /stats

# ── Channel / Group for subscription check ──────────────────────────────────
CHANNEL_USERNAME=@shadowlink_top  # Username канала (для кнопки подписки)
CHANNEL_ID=-1001234567890       # ID канала (число, можно получить через @userinfobot)

# ── 3x-ui Panel ──────────────────────────────────────────────────────────────
XUI_URL=http://your-server-ip:54321
XUI_USERNAME=admin
XUI_PASSWORD=your_xui_password
XUI_INBOUND_ID=1                # ID inbound из 3x-ui (обычно 1)

# ── VLESS Connection Link (optional — для /moy_klyuch) ───────────────────────
XUI_VLESS_DOMAIN=your.domain.com
XUI_VLESS_PORT=443
XUI_VLESS_SNI=your.domain.com
XUI_VLESS_FP=chrome
XUI_VLESS_NETWORK=ws
XUI_VLESS_PATH=/vless
XUI_VLESS_SECURITY=tls

# ── Webhook Server ────────────────────────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
PAYMENT_SECRET_KEY=change_this_to_random_secret_string  # для /webhook/generic

# ── CryptoBot (Telegram) — крипто без ИП ─────────────────────────────────────
# Получить токен: @CryptoBot → /newapp
# Testnet: @CryptoTestnetBot
CRYPTOBOT_TOKEN=
CRYPTOBOT_NETWORK=mainnet       # mainnet | testnet

# ── Lava.ru — карты + СБП без самозанятости ──────────────────────────────────
# Регистрация: https://lava.ru → Кабинет → API
LAVA_SHOP_ID=
LAVA_SECRET_KEY=

# ── Manual payment (перевод по номеру телефона) ─────────────────────────────
MANUAL_PAYMENT_PHONE=+79615160441  # Номер для перевода (СБП)

# ── YooMoney — карты + СБП ───────────────────────────────────────────────────
# Регистрация: https://yoomoney.ru → Кабинет → API
YOUMONEY_API_KEY=
YOUMONEY_SECRET=
YOUMONEY_ACCOUNT=410016988853881

# ── Paymaster.ru (VK Pay) — карты + СБП ──────────────────────────────────────
# Регистрация: https://paymaster.ru → Кабинет → API
# Тестовый токен: https://paymaster.ru/docs/test
PAYMASTER_TOKEN=                # Формат: merchant_id:TEST:secret или merchant_id:LIVE:secret
PAYMASTER_MERCHANT_ID=          # ID магазина из кабинета Paymaster

# ── Trial & Referral Settings ────────────────────────────────────────────────
TRIAL_ENABLED=true              # Включить триал (true/false)
TRIAL_DAYS=1                    # Длительность триала в днях
REFERRAL_BONUS_DAYS=3           # Бонус за реферала (дней)
